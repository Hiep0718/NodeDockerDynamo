<!DOCTYPE html>
<html>
<head>
    <title>Chi tiết sản phẩm</title>
    <style>
        .container { width: 400px; margin: 20px auto; border: 1px solid #ddd; padding: 20px; text-align: center; }
        img { width: 200px; height: auto; border-radius: 5px; }
        p { text-align: left; font-size: 16px; }
        .btn { padding: 8px 15px; text-decoration: none; color: white; border-radius: 3px; background: gray; display: inline-block; margin-top: 15px; }
    </style>
</head>
<body>
    <div class="container">
        <h2>Thông tin sản phẩm</h2>
        <img src="<%= product.url_image %>" alt="Hình ảnh sản phẩm">
        <hr>
        <p><strong>ID:</strong> <%= product.id %></p>
        <p><strong>Tên sản phẩm:</strong> <%= product.name %></p>
        <p><strong>Giá bán:</strong> <%= product.price %> VNĐ</p>
        <p><strong>Số lượng trong kho:</strong> <%= product.unit_in_stock %></p>
        
        <a href="/" class="btn">Quay lại danh sách</a>
    </div>
</body>
</html>