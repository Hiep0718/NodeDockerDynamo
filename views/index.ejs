<!DOCTYPE html>
<html>
<head>
    <title>Quản lý vé</title>
    <style>
        body { font-family: Arial, sans-serif; padding: 20px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #ddd; padding: 10px; text-align: left; }
        img { width: 80px; height: auto; }
        .btn { padding: 5px 10px; text-decoration: none; color: white; border-radius: 3px; cursor: pointer; border: none; font-size: 14px; }
        .btn-add { background: green; }
        .btn-edit { background: orange; }
        .btn-del { background: red; }
        .btn-back { background: gray; display: inline-block; margin-top: 15px; }
        
        form { width: 300px; margin: 20px 0; display: flex; flex-direction: column; gap: 10px; }
        input { padding: 8px; }
        .current-img { width: 100px; height: auto; display: block; margin-top: 5px; }
        .container { width: 400px; margin: 20px 0; border: 1px solid #ddd; padding: 20px; text-align: center; }
        .container img { width: 200px; height: auto; border-radius: 5px; }
        .container p { text-align: left; font-size: 16px; }
    </style>
</head>
<body>
    <% if (action === 'list') { %>
        <h1>Danh sách vé</h1>
        <a href="/add" class="btn btn-add">Thêm vé mới</a>
        <table>
            <thead>
                <tr>
                    <th>Mã QR</th>
                    <th>Tên sự kiện</th>
                    <th>Chủ dự án</th>
                    <th>Thể loại</th>
                    <th>Số lượng</th>
                    <th>Giá / vé</th>
                    <th>Ngày bắt đầu</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <% Tickets.forEach(ticket => { %>
                    <tr>
                        <td>
                            <% if (ticket.imageUrl) { %>
                                <img src="<%= ticket.imageUrl %>" alt="ticket">
                            <% } else { %>
                                <span>No Image</span>
                            <% } %>
                        </td>
                        <td><%= ticket.eventName %></td>
                        <td><%= ticket.holderName %></td>
                        <td><%= ticket.category %></td>
                        <td><%= ticket.quantity %></td>
                        <td><%= ticket.pricePerTicket %></td>
                        <td><%= ticket.eventDate %></td>
                        <td><%= ticket.status %></td>
                        <td><%= ticket.createdAt %></td>
                        <td>
                            <a href="/detail/<%= ticket.ticketId %>" class="btn" style="background: blue;">Xem</a> |
                            <a href="/edit/<%= ticket.ticketId %>" class="btn btn-edit">Sửa</a> |
                            <a href="/delete/<%= ticket.ticketId %>" class="btn btn-del" onclick="return confirm('Xác nhận xóa?')">Xóa</a>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

    <% } else if (action === 'add') { %>
        <h2>Thêm vé mới</h2>
        <form action="/add" method="POST" enctype="multipart/form-data">
            <input type="text" name="eventName" placeholder="Tên sự kiện" required>
            <input type="text" name="holderName" placeholder="Chủ đầu tư" required>
            <input type="text" name="category" placeholder="Loại sự kiện" required>
            <input type="number" name="quantity" placeholder="Số lượng" required>
            <input type="number" name="pricePerTicket" placeholder="Giá/vé" required>
            <input type="date" name="eventDate" placeholder="Ngày bắt đầu" required>
            <input type="text" name="status" placeholder="Trạng thái" required>
            <label>Chọn ảnh qr vé (Upload S3):</label>
            <input type="file" name="imageUrl" accept="image/*">
            <button type="submit" class="btn btn-add">Lưu vé</button>
            <a href="/" class="btn btn-back" style="text-align: center;">Quay lại danh sách</a>
        </form>

    <% } else if (action === 'edit') { %>
        <h2>Chỉnh sửa vé</h2>
        <form action="/edit/<%= ticket.ticketId %>" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="ticketId" value="<%= ticket.ticketId %>">
            <input type="hidden" name="old_image" value="<%= ticket.imageUrl %>">

            <label>Tên sự kiện:</label>
            <input type="text" name="eventName" value="<%= ticket.eventName %>" required>
            <label>Tên nhà đầu tư:</label>
            <input type="text" name="holderName" value="<%= ticket.holderName %>" required>
            <label>Loại sự kiện:</label>
            <input type="text" name="category" value="<%= ticket.category %>" required>
            <label>Số lượng:</label>
            <input type="number" name="quantity" value="<%= ticket.quantity %>" required>
            <label>Giá/vé:</label>
            <input type="number" name="pricePerTicket" value="<%= ticket.pricePerTicket %>" required>
            <label>Ngày bắt đầu:</label>
            <input type="date" name="eventDate" value="<%= ticket.eventDate %>" required>
            <label>Trạng thái:</label>
            <input type="text" name="status" value="<%= ticket.status %>" required>
            <label>Ảnh hiện tại trên S3:</label>
            <% if (ticket.imageUrl) { %>
                <img src="<%= ticket.imageUrl %>" class="current-img" alt="Ảnh qr vé">
            <% } else { %>
                <p>Chưa có ảnh</p>
            <% } %>

            <label>Đổi ảnh khác (Bỏ trống nếu giữ nguyên ảnh cũ):</label>
            <input type="file" name="image" accept="image/*">

            <button type="submit" class="btn btn-edit">Cập nhật vé</button>
            <a href="/" class="btn btn-back" style="text-align: center;">Quay lại danh sách</a>
        </form>

    <% } else if (action === 'detail') { %>
        <div class="container">
            <h2>Thông tin vé</h2>
            <% if (ticket.imageUrl) { %>
                <img src="<%= ticket.imageUrl %>" alt="ticket">
            <% } else { %>
                <span>No Image</span>
            <% } %>
            <hr>
            <p><strong>Tên sự kiện:</strong> <%= ticket.eventName %></p>
            <p><strong>Chủ đầu tư:</strong> <%= ticket.holderName %></p>
            <p><strong>Loại sự kiện:</strong> <%= ticket.category %></p>
            <p><strong>Số lượng:</strong> <%= ticket.quantity %></p>
            <p><strong>Giá/vé:</strong> <%= ticket.pricePerTicket %></p>
            <p><strong>Ngày bắt đầu:</strong> <%= ticket.eventDate %></p>
            <p><strong>Trạng thái:</strong> <%= ticket.status %></p>

            <a href="/" class="btn btn-back">Quay lại danh sách</a>
        </div>
    <% } %>
</body>
</html>