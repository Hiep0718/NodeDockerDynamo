<!DOCTYPE html>
<html>
<head>
    <title>Quản lý sản phẩm</title>
    <style>
        body { font-family: Arial, sans-serif; padding: 20px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #ddd; padding: 10px; text-align: left; }
        img { width: 80px; height: auto; }
        .btn { padding: 5px 10px; text-decoration: none; color: white; border-radius: 3px; cursor: pointer; border: none; font-size: 14px; }
        .btn-add { background: green; }
        .btn-edit { background: orange; }
        .btn-del { background: red; }
        .btn-back { background: gray; display: inline-block; margin-top: 15px; }
        
        form { width: 300px; margin: 20px 0; display: flex; flex-direction: column; gap: 10px; }
        input { padding: 8px; }
        .current-img { width: 100px; height: auto; display: block; margin-top: 5px; }
        .container { width: 400px; margin: 20px 0; border: 1px solid #ddd; padding: 20px; text-align: center; }
        .container img { width: 200px; height: auto; border-radius: 5px; }
        .container p { text-align: left; font-size: 16px; }
    </style>
</head>
<body>
    <% if (action === 'list') { %>
        <h1>Danh sách sản phẩm</h1>
        <a href="/add" class="btn btn-add">Thêm sản phẩm mới</a>
        <table>
            <thead>
                <tr>
                    <th>Hình ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>Giá</th>
                    <th>Số lượng</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <% products.forEach(product => { %>
                    <tr>
                        <td>
                            <% if (product.url_image) { %>
                                <img src="<%= product.url_image %>" alt="product">
                            <% } else { %>
                                <span>No Image</span>
                            <% } %>
                        </td>
                        <td><%= product.name %></td>
                        <td><%= product.price %> VNĐ</td>
                        <td><%= product.unit_in_stock %></td>
                        <td>
                            <a href="/detail/<%= product.id %>" class="btn" style="background: blue;">Xem</a> |
                            <a href="/edit/<%= product.id %>" class="btn btn-edit">Sửa</a> |
                            <a href="/delete/<%= product.id %>" class="btn btn-del" onclick="return confirm('Xác nhận xóa?')">Xóa</a>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

    <% } else if (action === 'add') { %>
        <h2>Thêm sản phẩm mới</h2>
        <form action="/add" method="POST" enctype="multipart/form-data">
            <input type="text" name="name" placeholder="Tên sản phẩm" required>
            <input type="number" name="price" placeholder="Giá" required>
            <input type="number" name="unit_in_stock" placeholder="Số lượng tồn" required>
            <label>Chọn ảnh sản phẩm (Upload S3):</label>
            <input type="file" name="image" accept="image/*" required>
            <button type="submit" class="btn btn-add">Lưu sản phẩm</button>
            <a href="/" class="btn btn-back" style="text-align: center;">Quay lại danh sách</a>
        </form>

    <% } else if (action === 'edit') { %>
        <h2>Chỉnh sửa sản phẩm</h2>
        <form action="/edit/<%= product.id %>" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="id" value="<%= product.id %>">
            <input type="hidden" name="old_image" value="<%= product.url_image %>">

            <label>Tên sản phẩm:</label>
            <input type="text" name="name" value="<%= product.name %>" required>

            <label>Giá (VNĐ):</label>
            <input type="number" name="price" value="<%= product.price %>" required>

            <label>Số lượng tồn:</label>
            <input type="number" name="unit_in_stock" value="<%= product.unit_in_stock %>" required>

            <label>Ảnh hiện tại trên S3:</label>
            <% if (product.url_image) { %>
                <img src="<%= product.url_image %>" class="current-img" alt="Ảnh sản phẩm">
            <% } else { %>
                <p>Chưa có ảnh</p>
            <% } %>

            <label>Đổi ảnh khác (Bỏ trống nếu giữ nguyên ảnh cũ):</label>
            <input type="file" name="image" accept="image/*">

            <button type="submit" class="btn btn-edit">Cập nhật sản phẩm</button>
            <a href="/" class="btn btn-back" style="text-align: center;">Quay lại danh sách</a>
        </form>

    <% } else if (action === 'detail') { %>
        <div class="container">
            <h2>Thông tin sản phẩm</h2>
            <% if (product.url_image) { %>
                <img src="<%= product.url_image %>" alt="Hình ảnh sản phẩm">
            <% } else { %>
                <p>Chưa có ảnh</p>
            <% } %>
            <hr>
            <p><strong>ID:</strong> <%= product.id %></p>
            <p><strong>Tên sản phẩm:</strong> <%= product.name %></p>
            <p><strong>Giá bán:</strong> <%= product.price %> VNĐ</p>
            <p><strong>Số lượng trong kho:</strong> <%= product.unit_in_stock %></p>
            
            <a href="/" class="btn btn-back">Quay lại danh sách</a>
        </div>
    <% } %>
</body>
</html>