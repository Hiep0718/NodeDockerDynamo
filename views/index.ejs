<!DOCTYPE html>
<html>
<head>
    <title>Quản lý sản phẩm</title>
    <style>
        table { width: 100%; border-collapse: collapse; }
        th, td { border: 1px solid #ddd; padding: 10px; text-align: left; }
        img { width: 80px; height: auto; }
        .btn { padding: 5px 10px; text-decoration: none; color: white; border-radius: 3px; }
        .btn-add { background: green; }
        .btn-edit { background: orange; }
        .btn-del { background: red; }
    </style>
</head>
<body>
    <h1>Danh sách sản phẩm</h1>
    <a href="/add" class="btn btn-add">Thêm sản phẩm mới</a>
    <br><br>
    <table>
        <thead>
            <tr>
                <th>Hình ảnh</th>
                <th>Tên sản phẩm</th>
                <th>Giá</th>
                <th>Số lượng</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            <% products.forEach(product => { %>
                <tr>
                    <td><img src="<%= product.url_image %>" alt="product"></td>
                    <td><%= product.name %></td>
                    <td><%= product.price %> VNĐ</td>
                    <td><%= product.unit_in_stock %></td>
                    <td>
                        <a href="/detail/<%= product.id %>">Xem</a> |
                        <a href="/edit/<%= product.id %>" class="btn btn-edit">Sửa</a> |
                        <a href="/delete/<%= product.id %>" class="btn btn-del" onclick="return confirm('Xóa hả?')">Xóa</a>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</body>
</html>